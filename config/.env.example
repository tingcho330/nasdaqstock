# cp .env.example .env 후 값을 채우세요. (.env 는 git 에 올리지 않습니다)

# --- Discord ---
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...
# background_risk_manager 전용 — config/.env 에만 설정 (.env.risk 파일 사용 안 함)
# 비어 있으면 DISCORD_WEBHOOK_URL 로 폴백
DISCORD_WEBHOOK_URL_RISK=https://discord.com/api/webhooks/...

# --- Naver Search API ---
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# --- OpenAI (선택) ---
OPENAI_API_KEY=

# --- KIS 실전 ---
KIS_MY_APP=
KIS_MY_SEC=
KIS_MY_ACCT_STOCK=
KIS_MY_PROD=01

# --- KIS 모의 ---
KIS_PAPER_APP=
KIS_PAPER_SEC=
KIS_MY_PAPER_STOCK=

# --- KIS 기타 (선택) ---
KIS_MY_HTSID=
# KIS_PROD_URL=   # 기본값 사용 시 비워둠
# KIS_VPS_URL=

# --- 실행 파라미터 (선택) ---
MARKET=SP500
SLOTS=3

# 로컬 실행 시 (Docker 외)
# CONFIG_PATH=./config/config.json
# OUTPUT_DIR=./output
# CACHE_DIR=./output/cache
# KIS_CONFIG_PATH=./config/kis_devlp.yaml
# KIS_TOKEN_FILE=./output/cache/kis_token.json

# --- 디버그 (선택) ---
DB_RECORD_DEBUG=0
DB_DEBUG_LOG_FILE=/app/output/debug/db_record_debug.log
