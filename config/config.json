{
  // ── 공통 ──────────────────────────────────────────────────────────
  // KIS API 환경: "prod"(실전) | "mock"(모의). config/.env 의 KIS_* 키와 함께 사용
  "trading_environment": "prod",

  // KIS Open API 호출 제한 (초당 요청·동시 연결). SP500 스크리너는 2/2 권장
  "kis_limits": {
    "max_rps": 2,           // 초당 최대 요청 수
    "max_concurrency": 2    // 동시 API 호출 상한
  },

  // ── 스크리너 (screener.py) ────────────────────────────────────────
  "screener_params": {
    // [KR] 최소 시가총액(원). KOSPI/KOSDAQ 1차 필터
    "min_market_cap": 50000000000,
    // [US] 최소 시가총액(USD). 마스터 미제공 시 스킵될 수 있음
    "min_market_cap_us": 5000000000,
    // [KR] 최대 시가총액(원)
    "max_market_cap": 50000000000000,
    // [US] 최대 시가총액(USD)
    "max_market_cap_us": 5000000000000,
    // [KR] 5일 평균 거래대금 하한(원)
    "min_trading_value_5d_avg": 100000000000,
    // [US] 5일 평균 거래대금 하한(USD). 5B=50억달러
    "min_trading_value_5d_avg_us": 5000000000,
    // 최종 후보 상위 N종 (섹터 다양화 전)
    "top_n": 8,
    // 종합 점수 가중치 (합≈1.0)
    "fin_weight": 0.25,       // 재무(PER/PBR 등)
    "tech_weight": 0.35,      // 기술(RSI/MA/패턴)
    "mkt_weight": 0.1,        // 시장 레짐
    "sector_weight": 0.1,     // 섹터 트렌드
    "vol_kki_weight": 0.05,   // 거래량 KKI
    "pos_52w_weight": 0.05,   // 52주 고점 대비 위치
    // 동일 섹터 비중 상한 (0~1)
    "sector_cap": 0.35,
    // 섹터 정보 소스 우선순위. SP500: ["kis","mst"] 권장
    "sector_source_priority": ["kis", "mst"],
    // 신규 상장 제외 일수
    "exclude_newly_listed_days": 20,
    // 연속 상승일 N일 초과 종목 제외
    "exclude_consecutive_up_days": 4,
    // 최소 종합 점수 (0~1). 미만 종목 탈락. GPT initial_filter·rebalance와 동기화 권장
    "min_score_threshold": 0.48,
    // false: 단기 모멘텀 음수 종목도 후보 포함
    "require_positive_momentum": false,
    // true: 변동성 과다 종목 제외
    "exclude_high_volatility": false,
    // 변동성 상한 (0~1, 0.90=90%). exclude_high_volatility=true 일 때 적용
    "volatility_threshold": 0.90,
    // OHLCV 최소 봉 수 (지표 계산용)
    "min_history_bars": 50,
    // true: 잔고 대비 매수 불가 종목 후보에서 제외
    "affordability_filter": true,
    // 매수 가능 금액 버퍼 (0.05=5% 여유)
    "affordability_buffer": 0.05
  },

  // ── 리스크 관리 (risk_manager.py / background_risk_manager) ───────
  "risk_params": {
    "max_positions": 8,              // 최대 보유 종목 수
    "cooldown_period_days": 20,      // 매도 후 동일 종목 재매수 쿨다운(일)
    "atr_period": 14,                // ATR 계산 기간
    "atr_k_stop": 2.0,               // ATR 배수 손절
    "reward_risk": 3.0,              // 익절:손절 비율
    "max_daily_loss_pct": 0.02,      // 일일 최대 손실률 (계좌 대비)
    "max_daily_loss_amount": 5000,   // 일일 최대 손실 금액 (USD/KRW)
    "stop_trading_on_consecutive_losses": 2,  // 연속 손실 N회 시 당일 매매 중단
    "stop_pct": 0.03,                // 고정 % 손절 (전략 보조)
    "cooldown_fail_threshold": 2,    // API 실패 N회 시 쿨다운
    "strategy_mode": "hybrid",       // hybrid | conservative | aggressive
    "enable_advanced_strategies": true,
    "auto_sell": {
      "enabled": true,
      "stop_loss_pct": 0.045,        // 자동 손절 %
      "target_pct": 0.07,            // 목표 익절 %
      "partial_profit_pct": 0.025,   // 부분 익절 트리거 %
      "partial_profit_ratio": 0.5,   // 부분 익절 비율
      "emergency_drop_pct": 0.13,    // 급락 시 즉시 매도 % (손익률 ≤ -13%)
      "direct_execute": true,        // true: risk_manager가 SELL 즉시 주문
      "direct_execute_partial": true, // true: PARTIAL_SELL 즉시 주문 (기본 true)
      "partial_execute_once": true,   // 종목당 부분익절 1회
      "partial_full_if_rounding_zero": true,  // 1주×50% → 전량 treat
      "cooldown_sec_per_ticker": 20  // 종목별 재매도 방지(초)
    },
    "rsi_take_profit": 82.0,         // RSI 과열 익절 기준
    "prev_close_break_sell": false,  // 전일 종가 이탈 시 매도
    "rsi_min_profit_pct": 0.012,     // RSI 익절 최소 수익률
    "rsi_take_profit_early": 85.0,   // 조기 RSI 익절
    "rsi_sell_strategy": {
      "enabled": false,
      "warning_level": 75.0,
      "sell_candidate_level": 80.0,
      "full_exit_level": 70.0,
      "confirm_conditions_required": 2,
      "mode": "partial",             // partial | full
      "partial_ratio": 0.3,
      "check_divergence": true,
      "check_trend_weakening": true,
      "check_volume_weakening": true
    }
  },

  // ── GPT 분석 (gpt_analyzer.py) ────────────────────────────────────
  "gpt_params": {
    "openai_model": "gpt-4o-mini",
    "budget_guard": true,            // 잔고 대비 과매수 방지
    "max_entry_price_ratio": 0.95,   // 1종목 최대 진입 비중 (trading_params.per_ticker_max_weight 와 동기화)
    "initial_filter": {
      "min_score_pass": 0.48,
      "min_score_no_news": 0.48,     // 뉴스 없을 때 최소 점수
      "heuristic_min_score": 0.48,
      "min_news_chars": 200          // 뉴스 본문 최소 글자 수
    },
    "analysis_expansion": {
      "enabled": true,
      "max_primary_candidates": 8,
      "max_total_analysis": 15
    }
  },

  // ── 뉴스 수집 (news_collector.py) ─────────────────────────────────
  "news_params": {
    "days": 14,                         // 최근 N일 (스윙: 14 권장, legacy 90)
    "articles_per_stock": 5,
    "scrape_body_us": true,             // US: RSS 링크 follow 후 본문 스크래핑
    "max_body_chars_per_article": 800,  // 기사별 본문 상한
    "max_gpt_text_chars": 1500,         // GPT용 text 필드 상한
    "dedupe_title_threshold": 0.85,
    "us_query_mode": "ticker_and_name", // ticker_only | ticker_and_name
    "scrape_rps": 2,                    // US 본문 스크래핑 초당 요청 상한
    "include_links_in_gpt_text": false  // false: URL은 articles[].url, text는 제목·요약·본문만
  },

  // ── 매매 전략 (strategies.py) ─────────────────────────────────────
  "strategy_params": {
    "stop_loss_pct": 0.03,
    "take_profit_pct": 0.06,
    "atr_k_stop": 2.5,
    "atr_k_profit": 4.0,
    "strategy_weights": {
      "RsiReversalStrategy": 0.6,
      "TrendFollowingStrategy": 0.8,
      "AdvancedTechnicalStrategy": 0.6,
      "DynamicAtrStrategy": 0.7,
      "BaseStrategy": 0.5
    },
    "sell_threshold": 1.0
  },

  // ── US 시장 레짐 (SP500 / SPX 지수) ───────────────────────────────
  "us_market_regime": {
    "source": "index",               // index | etf
    "index_market_code": "N",        // KIS 지수 시장코드 (N=NYSE)
    "index_symbol": "SPX",           // S&P 500 지수
    "lookback_calendar_days": 500,
    "min_bars": 200,
    "etf_fallback": {
      "enabled": true,
      "symbol": "SPY",
      "excd": "AMS"
    }
  },

  // ── 시장별 운영 시간 (KST) ─────────────────────────────────────────
  "market_hours": {
    "SP500": {
      // risk_manager 폴링 허용 구간 (미국 정규장 대응)
      "risk_poll_windows": ["22:30-05:00"]
    }
  },

  // ── 매매 실행 (trader.py) ─────────────────────────────────────────
  "trading_params": {
    "buy_enabled": true,
    "allow_rebuy": false,            // 동일 종목 추가 매수
    "max_legs_per_ticker": 1,
    "post_partial_sell_buy_cooldown_days": 5,
    "partial_sell_flag_ttl_days": 7,
    "per_ticker_max_weight": 0.95,   // 종목당 최대 비중 (gpt_params.max_entry_price_ratio 와 동기화)
    "position_sizing": {
      "mode": "rank_cascade",          // rank_cascade: GPT rank 순 잔액 연쇄 | equal_slots: 균등 분배
      "max_shares_per_order": null,    // null=무제한(예산 내 최대 주수), 정수=종목당 상한
      "reserve_final_cash": true       // 마지막 rank 매수 시 min_cash_reserve 유지
    },
    "min_holding_hours": 336,        // 최소 보유 14일 (PartialProfit 부분익절 제외)
    "min_order_cash": 100,           // 최소 주문 금액 (USD)
    "rebuy_atr_k": 0.5,
    "rebuy_rsi_ceiling": 72.0,
    "cash_buffer_ratio": 0.02,       // 현금 유지 비율
    "min_cash_reserve": 100,
    "dynamic_cash_management": {
      "enabled": false,
      "market_regime_adjustment": {
        "bull_market": 0.3,
        "sideways_market": 0.4,
        "bear_market": 0.6,
        "volatile_market": 0.5
      },
      "volatility_threshold": 0.25,
      "rebalance_frequency_hours": 6
    },
    // KST 기준 매수/매도 허용 시간대
    "buy_time_windows": ["22:35-04:45"],
    "sell_time_windows": ["22:30-05:00"],
    "split_buy": {
      "enabled": false,
      "slices": 5,
      "weights": [0.4, 0.3, 0.15, 0.1, 0.05],
      "ladder_ticks": [0, 1, 2, 3, 4],
      "interval_sec": 0.3,
      "jitter_sec": 0.1,
      "min_qty": 1,
      "min_cash_per_slice": 100
    },
    "fee_buffer_pct": 0.003,
    "retry_on_reject": true,
    "max_retries": 2,
    "retry_delay_ms": 400,
    "slippage_bps": 10,
    "commission_rate": 0.001,        // US: 해외 수수료 근사
    "securities_tax_rate": 0,
    "agricultural_tax_rate": 0,
    "slippage_rate": 0.001,
    "order_execution": {
      "execution_timeout_sec": 45,
      "execution_check_interval": 2,
      "execution_check_retries": 5,
      "dynamic_tick_enabled": true,
      "max_tick_adjustment": 3,
      "market_order_fallback": true,
      "retry_on_partial_execution": true,
      "low_priority_threshold": 2,
      "cancel_pendings_before_fallback": true,
      "confirm_previous_done": true,
      "fallback_only_remaining_qty": true,
      "split_timebox_sec": 20,
      "split_step_min_delay_sec": 1.0
    }
  },

  // ── 알림 ───────────────────────────────────────────────────────────
  "notifications": {
    "discord_cooldown_sec": 60,
    "snapshot_change_threshold_pct": 1.0
  },

  // ── 매매 가드 (잔고·슬롯) ─────────────────────────────────────────
  "trading_guards": {
    "auto_shrink_slots": true,       // 자금 부족 시 슬롯 자동 축소
    "min_total_cash_to_trade": 300,
    "skip_when_low_funds": true,
    "enforce_per_ticker_limit": true
  },

  // ── 리포팅 ─────────────────────────────────────────────────────────
  "reporting": {
    "coherent_summary": true,
    "include_cash_breakdown": true
  },

  "prompting": {
    "core_questions": true
  },

  // ── 종목 회전 (rotation_manager) ──────────────────────────────────
  "rotation": {
    "enabled": false,
    "min_holding_days": 14,          // rotation/손절·RSI — min_holding_hours(336h)와 동일 14일
    "delta_score_min": 0.12          // 교체 최소 점수 차이
  },

  // ── 일일 요약 (integrated_manager) ────────────────────────────────
  "daily_summary": {
    "enabled": true,
    "balance_open_time": "22:45",   // KST 장 시작 전 잔고
    "balance_close_time": "06:00",    // KST 장 마감 후 잔고
    "summary_send_time": "06:15"      // Discord 요약 발송
  },

  // ── 스케줄 (KST, integrated_manager) ──────────────────────────────
  "schedule_times": {
    "screener_time": "22:50",         // 저녁 스크리너 (pm 세션)
    "pipeline_time": "23:30"          // GPT+매매 파이프라인
  },
  "pipeline_sessions": {
    "pm_start": "22:00",              // pm 세션 시작 (KST)
    "am_end": "06:30"                   // am 세션 종료 (KST)
  },

  "monthly_maintenance": {
    "day": 1,
    "time": "16:00"
  },

  // ── GPT + 내부 점수 통합 (trader 리밸런싱) ───────────────────────
  "integrated_analysis": {
    "enabled": true,
    "gpt_weight": 0.65,
    "internal_weight": 0.35,
    "respect_gpt_hold": true,
    "enhanced_logging": true,
    "log_gpt_rotation_suggestions": true,
    "min_confidence_for_rotation": 0.9,
    "decision_transparency": {
      "enabled": true
    }
  },

  "rebalance_params": {
    "use_gpt_analysis": true,
    "screener_top_n": 8,
    "min_score_threshold": 0.48
  },

  // ── 체결 확인·주문 리컨실 (integrated_manager) ────────────────────
  "batch_execution_check": {
    "enabled": true,
    "check_time": "06:05",
    "window_minutes": 5
  },
  "order_reconcile": {
    "enabled": true,
    "reconcile_time": "06:10",
    "minutes_after_batch": 5
  }
}
